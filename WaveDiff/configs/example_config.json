{
  "model_type": "adaptive_wavelet",
  "latent_dim": 64,
  "timesteps": 1000,
  "use_batchnorm": true,
  "norm_type": "group",
  "norm_groups": 8,
  "cross_attention_mode": "channel",
  "attention_window_size": 8,
  "enhanced_attention_mode": "channel",
  "conditional_residual_diffusion": true,
  "residual_scale": 1.0,
  "batch_size": 8,
  "gradient_accumulation_steps": 2,
  "npy_cache_size": 8,
  "val_npy_cache_size": 8,
  "use_ema": true,
  "ema_decay": 0.999,
  "use_torch_compile": false,
  "compile_mode": "default",
  "learning_rate": 1e-4,
  "min_lr": 1e-6,
  "weight_decay": 0.01,
  "max_grad_norm": 1.0,
  "num_epochs": 100,
  "num_workers": 4,
  "diffusion_loss_weight": 1.0,
  "l1_loss_weight": 1.0,
  "cycle_loss_weight": 0.8,
  "wavelet_loss_weight": 0.5,
  "train_dir": "data/ARAD1K/train",
  "val_dir": "data/ARAD1K/val",
  "image_size": 256,
  "use_masking": true,
  "mask_strategy": "curriculum",
  "curriculum_strategies": ["random", "block", "spectral", "combined"],
  "checkpoint_dir": "checkpoints/adaptive_wavelet",
  "visualization_dir": "visualizations/adaptive_wavelet",
  "resume_from_checkpoint": null,
  "log_interval": 100,
  "threshold_method": "soft",
  "init_threshold": 0.1,
  "trainable_threshold": true,
  "initial_mask_ratio": 0.1,
  "final_mask_ratio": 0.7
}
